#!/usr/bin/env bash
set -euo pipefail

REGISTRY="192.168.0.145:3007"
IMAGE="${REGISTRY}/akitaonrails/frank_fbi"
TAG="${1:-latest}"

echo "==> Building image..."
docker build -t "${IMAGE}:${TAG}" .

echo "==> Pushing to ${REGISTRY}..."
docker push "${IMAGE}:${TAG}"

SERVER="192.168.0.145"
SSH_PORT="2022"
SSH_USER="akitaonrails"
COMPOSE_DIR="/home/${SSH_USER}/docker"
COMPOSE_FILE="frank_fbi.yml"

echo "==> Deploying on ${SERVER}..."
ssh -p "${SSH_PORT}" "${SSH_USER}@${SERVER}" \
  "cd ${COMPOSE_DIR} && docker compose -f ${COMPOSE_FILE} pull && docker compose -f ${COMPOSE_FILE} down && docker compose -f ${COMPOSE_FILE} up -d"

echo "==> Done."
