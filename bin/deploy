#!/usr/bin/env bash
set -euo pipefail

REGISTRY="192.168.0.90:3007"
IMAGE="${REGISTRY}/akitaonrails/frank_fbi"
TAG="${1:-latest}"

echo "==> Building image..."
docker build -t "${IMAGE}:${TAG}" .

echo "==> Pushing to ${REGISTRY}..."
docker push "${IMAGE}:${TAG}"

SERVER="192.168.0.90"
SSH_PORT="22"
SSH_USER="akitaonrails"
REMOTE_DIR="/var/opt/docker/frank_fbi"
LOCAL_COMPOSE_FILE="docker-compose.production.yml"
REMOTE_COMPOSE_FILE="docker-compose.yml"

echo "==> Uploading compose template to ${SERVER}:${REMOTE_DIR}/${REMOTE_COMPOSE_FILE}..."
scp -P "${SSH_PORT}" "${LOCAL_COMPOSE_FILE}" \
  "${SSH_USER}@${SERVER}:${REMOTE_DIR}/${REMOTE_COMPOSE_FILE}"

echo "==> Deploying on ${SERVER}..."
ssh -p "${SSH_PORT}" "${SSH_USER}@${SERVER}" \
  "cd ${REMOTE_DIR} && docker compose -f ${REMOTE_COMPOSE_FILE} pull && docker compose -f ${REMOTE_COMPOSE_FILE} up -d && docker compose -f ${REMOTE_COMPOSE_FILE} ps"

echo "==> Done."
