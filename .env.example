# Rails secret key base (generate with: ruby -rsecurerandom -e 'puts SecureRandom.hex(64)')
SECRET_KEY_BASE=

# Active Record Encryption (generate with: bin/rails db:encryption:init)
ACTIVE_RECORD_ENCRYPTION_PRIMARY_KEY=
ACTIVE_RECORD_ENCRYPTION_DETERMINISTIC_KEY=
ACTIVE_RECORD_ENCRYPTION_KEY_DERIVATION_SALT=

# Gmail IMAP/SMTP
GMAIL_USERNAME=your-email@gmail.com
GMAIL_PASSWORD=your-app-password
GMAIL_IMAP_HOST=imap.gmail.com
GMAIL_SMTP_HOST=smtp.gmail.com

# Action Mailbox
ACTION_MAILBOX_INGRESS_PASSWORD=your-ingress-password

# OpenRouter API (for LLM analysis)
OPENROUTER_API_KEY=your-openrouter-key

# VirusTotal API
VIRUSTOTAL_API_KEY=your-virustotal-key

# WhoisXML API
WHOISXML_API_KEY=your-whoisxml-key

# Admin email (receives commands, manages allowed senders)
ADMIN_EMAIL=admin@example.com

# App host (for mail_fetcher relay)
APP_HOST=http://localhost:3000
